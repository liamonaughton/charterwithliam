# Public site URL (used for absolute links, OG, redirects)
NEXT_PUBLIC_SITE_URL=https://charterwithliam.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=          # server only — never expose

# Resend
RESEND_API_KEY=
RESEND_FROM="Liam <liam@charterwithliam.com>"
RESEND_REPLY_TO=liam@charterwithliam.com

# Lead magnet (Supabase Storage)
LEAD_MAGNET_BUCKET=lead-magnets
LEAD_MAGNET_PATH=charter-buyers-guide.pdf
LEAD_MAGNET_SIGNED_URL_TTL_SECONDS=604800   # 7 days
# Fallback download link emailed when no Storage signed URL is available.
# Defaults to <NEXT_PUBLIC_SITE_URL>/charter-buyers-guide.pdf (served from /public).
LEAD_MAGNET_PUBLIC_URL=

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=     # public widget key
TURNSTILE_SECRET_KEY=               # server only

# Optional: Upstash rate limiting (falls back to in-memory if unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Physical mailing address for CAN-SPAM footer
NEXT_PUBLIC_MAILING_ADDRESS="CharterWithLiam, 123 Example St, City, ST 00000"

# Trust line social proof count (rendered in hero)
NEXT_PUBLIC_SUBSCRIBER_COUNT=2,000
